<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane prefWidth="1280.0" prefHeight="760.0" fitToWidth="true" fitToHeight="true" pannable="true" styleClass="scroll-container" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
   <content>
      <VBox spacing="20.0" styleClass="view-container">
         <children>
            <Label text="Importación de KPIs y análisis global" styleClass="view-title" />

            <HBox spacing="12.0">
               <children>
                  <Button text="Importar CSV" onAction="#importarCSV" styleClass="action-button" />
                  <Button text="Refrescar" onAction="#refrescarKpis" styleClass="action-button" />
                  <Button text="Exportar Excel" onAction="#exportarKpisExcel" styleClass="action-button" />
               </children>
            </HBox>

            <Label text="KPIs globales" styleClass="section-title" />

            <TableView fx:id="kpisGlobalesTableView" VBox.vgrow="ALWAYS" prefHeight="200.0" styleClass="data-table">
               <columns>
                  <TableColumn fx:id="metricaColumn" prefWidth="250.0" text="Métrica" />
                  <TableColumn fx:id="valorColumn" prefWidth="200.0" text="Valor" />
                  <TableColumn fx:id="unidadColumn" prefWidth="150.0" text="Unidad" />
                  <TableColumn fx:id="observacionesColumn" prefWidth="280.0" text="Observaciones" />
               </columns>
            </TableView>

            <Label text="KPIs por categoría (facturación)" styleClass="section-title" />

            <TableView fx:id="kpisPorCategoriaTableView" VBox.vgrow="ALWAYS" prefHeight="250.0" styleClass="data-table">
               <columns>
                  <TableColumn fx:id="categoriaColumn" prefWidth="250.0" text="Categoría" />
                  <TableColumn fx:id="facturacionColumn" prefWidth="200.0" text="Facturación Total" />
                  <TableColumn fx:id="margenColumn" prefWidth="200.0" text="Margen Total" />
                  <TableColumn fx:id="margenPorcentajeColumn" prefWidth="150.0" text="Margen %" />
               </columns>
            </TableView>
         </children>
      </VBox>
   </content>
</ScrollPane>