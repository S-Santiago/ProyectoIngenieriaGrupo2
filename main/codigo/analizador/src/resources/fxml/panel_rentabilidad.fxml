<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane prefWidth="1280.0" prefHeight="760.0" fitToWidth="true" fitToHeight="true" pannable="true" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" style="-fx-background: linear-gradient(to bottom right, #f7f9fc, #eef3f9); -fx-background-color: transparent;">
   <content>
      <VBox spacing="14.0" style="-fx-background-color: linear-gradient(to bottom right, #f7f9fc, #eef3f9);">
         <padding>
            <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
         </padding>
         <children>
            <Label text="Panel de Rentabilidad y Análisis Detallado" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1f2937;" />

            <HBox spacing="10.0">
               <children>
                  <Button text="Refrescar Datos" onAction="#refrescarPanel" style="-fx-font-size: 12px; -fx-padding: 8px 16px;" />
                  <Button text="Detectar Bajo Margen" onAction="#detectarBajoMargen" style="-fx-font-size: 12px; -fx-padding: 8px 16px;" />
                  <Button text="Mostrar Desviaciones" onAction="#mostrarDesviaciones" style="-fx-font-size: 12px; -fx-padding: 8px 16px;" />
                  <Button text="Exportar Análisis" onAction="#exportarAnalisis" style="-fx-font-size: 12px; -fx-padding: 8px 16px;" />
               </children>
            </HBox>

            <TitledPane text="Ranking de Categorías por Facturación" expanded="true">
               <VBox spacing="8.0">
                  <TableView fx:id="rankingCategoriasTableView" VBox.vgrow="ALWAYS" prefHeight="150.0">
                     <columns>
                        <TableColumn fx:id="rankPosicionColumn" prefWidth="80.0" text="Posición" />
                        <TableColumn fx:id="rankCategoriaColumn" prefWidth="250.0" text="Categoría" />
                        <TableColumn fx:id="rankFacturacionColumn" prefWidth="200.0" text="Facturación" />
                        <TableColumn fx:id="rankMargenColumn" prefWidth="200.0" text="Margen Bruto" />
                        <TableColumn fx:id="rankMargenPorcentajeColumn" prefWidth="150.0" text="Margen %" />
                     </columns>
                  </TableView>
               </VBox>
            </TitledPane>

            <TitledPane text="Líneas de Pedido Bajo Margen Mínimo (Incidencias)" expanded="true">
               <VBox spacing="8.0">
                  <TableView fx:id="lineasBajoMargenTableView" VBox.vgrow="ALWAYS" prefHeight="180.0">
                     <columns>
                        <TableColumn fx:id="idLineaColumn" prefWidth="80.0" text="ID Línea" />
                        <TableColumn fx:id="productoColumn" prefWidth="250.0" text="Producto" />
                        <TableColumn fx:id="categoriaColumn" prefWidth="150.0" text="Categoría" />
                        <TableColumn fx:id="margenActualColumn" prefWidth="120.0" text="Margen %" />
                        <TableColumn fx:id="margenRequeridoColumn" prefWidth="120.0" text="Requerido %" />
                        <TableColumn fx:id="deficienciaColumn" prefWidth="120.0" text="Deficiencia" />
                     </columns>
                  </TableView>
                  <Label fx:id="contadorBajoMargenLabel" text="Incidencias encontradas: 0" style="-fx-font-size: 12px; -fx-text-fill: #ef4444;" />
               </VBox>
            </TitledPane>

            <TitledPane text="Desviación de Objetivos por Zona" expanded="true">
               <VBox spacing="8.0">
                  <TableView fx:id="desviacionesZonasTableView" VBox.vgrow="ALWAYS" prefHeight="150.0">
                     <columns>
                        <TableColumn fx:id="zonaColumn" prefWidth="150.0" text="Zona" />
                        <TableColumn fx:id="paisColumn" prefWidth="120.0" text="País" />
                        <TableColumn fx:id="objetivoZonaColumn" prefWidth="150.0" text="Objetivo Anual" />
                        <TableColumn fx:id="realizadoZonaColumn" prefWidth="150.0" text="Facturación Real" />
                        <TableColumn fx:id="desviacionColumn" prefWidth="150.0" text="Desviación (€)" />
                        <TableColumn fx:id="porcentajeZonaColumn" prefWidth="120.0" text="Cumplimiento %" />
                     </columns>
                  </TableView>
               </VBox>
            </TitledPane>
         </children>
      </VBox>
   </content>
</ScrollPane>
